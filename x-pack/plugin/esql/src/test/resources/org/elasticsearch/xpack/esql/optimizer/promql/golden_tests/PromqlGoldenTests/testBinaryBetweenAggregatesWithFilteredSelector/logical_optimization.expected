Project[[ratio{r}#0, step{r}#1]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(ratio{r}#0)]
    \_Eval[[TODOUBLE(ratio{r}#2) / TODOUBLE(ratio{r}#3) AS ratio#4, TODOUBLE(ratio{r}#4) AS ratio#0]]
      \_Filter[step{r}#1 >= 0[DATETIME] AND step{r}#1 <= 253402300799999[DATETIME]]
        \_Aggregate[[step{r}#1],[SUM(RATE_$1{r}#5,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS ratio_$1#2, SUM(RATE_$2{r}#6,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS ratio_$2#3, step{r}#1]]
          \_TimeSeriesAggregate[[_tsid{m}#7, step{r}#1],[RATE(network.total_bytes_in{f}#8,cluster{f}#9 == prod[KEYWORD],PT5M[TIME_DURATION],@timestamp{f}#10) AS RATE_$1#5, RATE(network.total_bytes_in{f}#8,true[BOOLEAN],PT5M[TIME_DURATION],@timestamp{f}#10) AS RATE_$2#6, step{r}#1 AS step#1],BUCKET(@timestamp{f}#10,PT5M[TIME_DURATION]),BUCKET(@timestamp{f}#10,PT5M[TIME_DURATION]),@timestamp{f}#10,PROMQL_COMMAND]
            \_Eval[[BUCKET(@timestamp{f}#10,PT5M[TIME_DURATION]) AS step#1]]
              \_EsRelation[k8s][TIME_SERIES][@timestamp{f}#10, client.ip{f}#11, cluster{f}#9, event{f}#12, event_city{f}#13, event_city_boundary{f}#14, event_location{f}#15, event_log{f}#16, event_shape{f}#17, events_received{f}#18, network.bytes_in{f}#19, network.cost{f}#20, network.eth0.currently_connected_clients{f}#21, network.eth0.firmware_version{f}#22, network.eth0.last_up{f}#23, network.eth0.rx{f}#24, network.eth0.tx{f}#25, network.eth0.up{f}#26, network.total_bytes_in{f}#8, network.total_bytes_out{f}#27, network.total_cost{f}#28, pod{f}#29, region{f}#30, _tsid{m}#7]